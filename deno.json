{
  "tasks": {
    "dev": "deno task dev:backend & deno task dev:frontend",
    "dev:backend": "deno run --watch --allow-net --allow-read --allow-env server/main.ts",
    "dev:frontend": "deno run -A npm:vite@6 --config client/vite.config.ts",
    "build": "deno run -A npm:vite@6 build --config client/vite.config.ts",
    "preview": "deno run --allow-net --allow-read --allow-env server/main.ts",
    "deploy": "deno task build"
  },
  "imports": {
    "@std/assert": "jsr:@std/assert@1",
    "hono": "jsr:@hono/hono@4",
    "react": "npm:react@19",
    "react-dom": "npm:react-dom@19",
    "react-dom/client": "npm:react-dom@19/client",
    "three": "npm:three@0.172",
    "@react-three/fiber": "npm:@react-three/fiber@9",
    "@react-three/drei": "npm:@react-three/drei@10"
  },
  "nodeModulesDir": "auto",
  "compilerOptions": {
    "jsx": "react-jsx",
    "jsxImportSource": "react"
  }
}
